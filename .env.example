# Banking Ledger — Environment Configuration
# Copy to .env and adjust ports as needed

# SurrealDB container
SURREAL_USER=root
SURREAL_PASS=root

# API port (change if 3001 is in use)
API_PORT=3001

# SurrealDB host port (change if 4321 is in use)
# docker compose maps HOST_PORT:8000
SURREAL_HOST_PORT=4321
